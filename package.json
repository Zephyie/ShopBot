{
  "name": "shopbot",
  "version": "2.4.1",
  "author": "roules-dev",
  "funding": "https://ko-fi.com/roules_",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc && npx tsc-alias",
    "clean:dist": "(rd /s /q dist || rm -rf dist) && mkdir dist",
    "build:clean": "npm run clean:dist --silent && npm run build",
    "build:prod": "npm run clean:dist --silent && tsc -p tsconfig.build.json && npx tsc-alias",
    "dev": "nodemon src/index.ts",
    "start": "npm run build && npm run serve",
    "serve": "node --enable-source-maps dist/index.js",
    "deploy": "node ./dist/app/deploy-commands.js",
    "test": "npm run build && node ./dist/test.js",
    "setup": "npm i --omit=dev --silent && node ./dist/tools/setup-helper.js",
    "migrate-db-to-nanoid": "node ./dist/tools/migrate-db-to-nanoid.js",
    "verify-translation": "node ./dist/tools/verify-translation.js",
    "generate:locales": "node ./dist/tools/generate-locales.js"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^25.0.3",
  },
  "dependencies": {
    "typescript": "^5.0.0",
    "tsc-alias": "^1.8.10",
    "@discordjs/rest": "^2.6.0",
    "discord.js": "^14.15.1",
    "dotenv": "^16.4.5",
    "fs": "^0.0.1-security",
    "luxon": "^3.5.0",
    "nanoid": "^5.1.6"
  },
}
